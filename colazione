<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>B&B Breakfast Order</title>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --cream: #fff7ec;
      --cream-2: #ffe9cf;
      --brown: #6b3f25;
      --brown-dark: #3b2114;
      --gold: #d7a85b;
      --rose: #f7b7a3;
      --green: #91b88c;
      --white: #ffffff;
      --shadow: 0 20px 55px rgba(80, 45, 20, 0.22);
      --radius: 28px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: 'Poppins', sans-serif;
      color: var(--brown-dark);
      background:
        radial-gradient(circle at 20% 15%, rgba(255,255,255,0.85), transparent 28%),
        radial-gradient(circle at 85% 5%, rgba(247,183,163,0.55), transparent 24%),
        linear-gradient(145deg, #fff8ef 0%, #ffe3c2 48%, #f8c9ad 100%);
      overflow-x: hidden;
    }

    .background-orb {
      position: fixed;
      border-radius: 999px;
      filter: blur(2px);
      opacity: 0.55;
      z-index: 0;
      pointer-events: none;
    }

    .orb-1 {
      width: 260px;
      height: 260px;
      background: rgba(215,168,91,0.35);
      top: -70px;
      left: -70px;
    }

    .orb-2 {
      width: 220px;
      height: 220px;
      background: rgba(145,184,140,0.35);
      bottom: -60px;
      right: -50px;
    }

    .page {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 520px;
      margin: 0 auto;
      padding: 26px 18px 34px;
    }

    .hero {
      position: relative;
      overflow: hidden;
      border-radius: 36px;
      padding: 30px 24px 26px;
      background:
        linear-gradient(160deg, rgba(255,255,255,0.82), rgba(255,246,233,0.55)),
        url("https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&w=1200&q=80");
      background-size: cover;
      background-position: center;
      min-height: 250px;
      box-shadow: var(--shadow);
      color: white;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(160deg, rgba(59,33,20,0.78), rgba(107,63,37,0.38), rgba(255,255,255,0.08));
      z-index: 0;
    }

    .hero-content {
      position: relative;
      z-index: 1;
    }

    .logo {
      width: 82px;
      height: 82px;
      border-radius: 26px;
      background: rgba(255,255,255,0.92);
      color: var(--brown);
      display: grid;
      place-items: center;
      font-family: 'Playfair Display', serif;
      font-size: 31px;
      font-weight: 700;
      box-shadow: 0 14px 30px rgba(0,0,0,0.18);
      margin-bottom: 18px;
    }

    .tag {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 8px 13px;
      border-radius: 999px;
      background: rgba(255,255,255,0.18);
      backdrop-filter: blur(10px);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.4px;
      margin-bottom: 12px;
    }

    h1 {
      margin: 0;
      font-family: 'Playfair Display', serif;
      font-size: 38px;
      line-height: 1;
      letter-spacing: -0.8px;
    }

    .subtitle {
      margin: 12px 0 0;
      font-size: 14px;
      line-height: 1.5;
      max-width: 330px;
      opacity: 0.95;
    }

    .room-card {
      margin-top: -28px;
      position: relative;
      z-index: 3;
      background: rgba(255,255,255,0.88);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(255,255,255,0.65);
      border-radius: 26px;
      padding: 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 16px 40px rgba(72,39,18,0.16);
    }

    .room-label {
      font-size: 12px;
      color: rgba(59,33,20,0.62);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }

    .room-number {
      font-size: 25px;
      font-weight: 800;
      color: var(--brown-dark);
      margin-top: 2px;
    }

    .room-icon {
      width: 54px;
      height: 54px;
      border-radius: 20px;
      background: linear-gradient(145deg, var(--gold), #f1d08c);
      display: grid;
      place-items: center;
      font-size: 25px;
      box-shadow: 0 10px 25px rgba(215,168,91,0.35);
    }

    .section-title {
      margin: 26px 4px 14px;
      display: flex;
      justify-content: space-between;
      align-items: end;
    }

    .section-title h2 {
      margin: 0;
      font-family: 'Playfair Display', serif;
      font-size: 27px;
      color: var(--brown-dark);
    }

    .section-title span {
      font-size: 12px;
      color: rgba(59,33,20,0.6);
      font-weight: 600;
    }

    .foods {
      display: grid;
      grid-template-columns: 1fr;
      gap: 13px;
    }

    .food-card {
      position: relative;
    }

    .food-card input {
      display: none;
    }

    .food-content {
      cursor: pointer;
      border-radius: 24px;
      background: rgba(255,255,255,0.74);
      border: 1px solid rgba(255,255,255,0.75);
      padding: 15px;
      display: flex;
      gap: 14px;
      align-items: center;
      box-shadow: 0 12px 30px rgba(84,47,21,0.10);
      transition: 0.22s ease;
    }

    .food-content:hover {
      transform: translateY(-2px);
      box-shadow: 0 16px 35px rgba(84,47,21,0.15);
    }

    .food-card input:checked + .food-content {
      background: linear-gradient(145deg, rgba(255,255,255,0.94), rgba(255,244,224,0.96));
      border: 2px solid var(--gold);
      transform: scale(1.015);
    }

    .emoji {
      width: 58px;
      height: 58px;
      min-width: 58px;
      border-radius: 22px;
      display: grid;
      place-items: center;
      font-size: 30px;
      background: linear-gradient(145deg, #fff1dc, #ffd7bc);
    }

    .food-title {
      font-weight: 800;
      font-size: 15px;
      color: var(--brown-dark);
      margin-bottom: 3px;
    }

    .food-desc {
      font-size: 12px;
      line-height: 1.4;
      color: rgba(59,33,20,0.63);
    }

    .check {
      margin-left: auto;
      width: 26px;
      height: 26px;
      border-radius: 999px;
      border: 2px solid rgba(107,63,37,0.18);
      display: grid;
      place-items: center;
      font-size: 14px;
      color: white;
      transition: 0.2s ease;
    }

    .food-card input:checked + .food-content .check {
      background: var(--green);
      border-color: var(--green);
    }

    .notes {
      margin-top: 16px;
    }

    textarea {
      width: 100%;
      min-height: 92px;
      resize: none;
      border: 0;
      outline: none;
      border-radius: 24px;
      padding: 16px;
      font-family: 'Poppins', sans-serif;
      font-size: 14px;
      background: rgba(255,255,255,0.78);
      box-shadow: 0 12px 30px rgba(84,47,21,0.10);
      color: var(--brown-dark);
    }

    textarea::placeholder {
      color: rgba(59,33,20,0.45);
    }

    .send-btn {
      margin-top: 18px;
      width: 100%;
      border: none;
      border-radius: 24px;
      padding: 18px 20px;
      font-family: 'Poppins', sans-serif;
      font-size: 16px;
      font-weight: 800;
      color: white;
      background: linear-gradient(135deg, var(--brown-dark), var(--brown), var(--gold));
      box-shadow: 0 18px 38px rgba(74,39,18,0.32);
      cursor: pointer;
      transition: 0.22s ease;
    }

    .send-btn:active {
      transform: scale(0.98);
    }

    .footer {
      margin-top: 18px;
      text-align: center;
      font-size: 12px;
      color: rgba(59,33,20,0.55);
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 22px;
      transform: translateX(-50%) translateY(120px);
      width: calc(100% - 34px);
      max-width: 470px;
      padding: 16px 18px;
      border-radius: 22px;
      background: rgba(59,33,20,0.95);
      color: white;
      box-shadow: 0 16px 40px rgba(0,0,0,0.22);
      font-size: 14px;
      z-index: 20;
      transition: 0.3s ease;
      text-align: center;
    }

    .toast.show {
      transform: translateX(-50%) translateY(0);
    }

    @media (min-width: 600px) {
      .page {
        padding-top: 40px;
      }

      h1 {
        font-size: 43px;
      }
    }
  </style>
</head>

<body>
  <div class="background-orb orb-1"></div>
  <div class="background-orb orb-2"></div>

  <main class="page">
    <section class="hero">
      <div class="hero-content">
        <div class="logo">B&B</div>
        <div class="tag">☕ Colazione in camera</div>
        <h1>Buongiorno,<br>scegli la tua colazione</h1>
        <p class="subtitle">
          Seleziona cosa desideri ricevere domani mattina. Il tuo ordine sarà inviato direttamente alla reception.
        </p>
      </div>
    </section>

    <section class="room-card">
      <div>
        <div class="room-label">Camera rilevata</div>
        <div class="room-number" id="roomNumber">Camera --</div>
      </div>
      <div class="room-icon">🛎️</div>
    </section>

    <div class="section-title">
      <h2>Menù breakfast</h2>
      <span>Scegli una o più voci</span>
    </div>

    <form id="breakfastForm">
      <div class="foods">

        <label class="food-card">
          <input type="checkbox" name="food" value="Cappuccino e cornetto">
          <div class="food-content">
            <div class="emoji">🥐</div>
            <div>
              <div class="food-title">Cappuccino e cornetto</div>
              <div class="food-desc">Classico italiano, semplice e perfetto.</div>
            </div>
            <div class="check">✓</div>
          </div>
        </label>

        <label class="food-card">
          <input type="checkbox" name="food" value="Colazione dolce completa">
          <div class="food-content">
            <div class="emoji">🍰</div>
            <div>
              <div class="food-title">Colazione dolce completa</div>
              <div class="food-desc">Dolci, marmellata, burro, succo e caffè.</div>
            </div>
            <div class="check">✓</div>
          </div>
        </label>

        <label class="food-card">
          <input type="checkbox" name="food" value="Toast salato">
          <div class="food-content">
            <div class="emoji">🥪</div>
            <div>
              <div class="food-title">Toast salato</div>
              <div class="food-desc">Toast caldo con prosciutto e formaggio.</div>
            </div>
            <div class="check">✓</div>
          </div>
        </label>

        <label class="food-card">
          <input type="checkbox" name="food" value="Yogurt, frutta e cereali">
          <div class="food-content">
            <div class="emoji">🍓</div>
            <div>
              <div class="food-title">Yogurt, frutta e cereali</div>
              <div class="food-desc">Fresco, leggero e colorato.</div>
            </div>
            <div class="check">✓</div>
          </div>
        </label>

        <label class="food-card">
          <input type="checkbox" name="food" value="Pancake con miele">
          <div class="food-content">
            <div class="emoji">🥞</div>
            <div>
              <div class="food-title">Pancake con miele</div>
              <div class="food-desc">Soffice, caldo, con miele o crema.</div>
            </div>
            <div class="check">✓</div>
          </div>
        </label>

      </div>

      <div class="notes">
        <textarea id="notes" placeholder="Note o richieste particolari... es. senza lattosio, orario preferito, allergie"></textarea>
      </div>

      <button class="send-btn" type="submit">Invia ordine colazione ✨</button>
    </form>

    <div class="footer">
      B&B Demo Luxury Breakfast · Interfaccia V1
    </div>
  </main>

  <div class="toast" id="toast"></div>

  <script>
    const CONFIG = {
      emailDestinatario: "tuaemail@example.com",
      nomeBB: "B&B Demo Luxury"
    };

    function getRoomFromUrl() {
      const params = new URLSearchParams(window.location.search);
      return params.get("room") || params.get("camera") || "NON RILEVATA";
    }

    const room = getRoomFromUrl();
    document.getElementById("roomNumber").textContent = "Camera " + room;

    function showToast(message) {
      const toast = document.getElementById("toast");
      toast.textContent = message;
      toast.classList.add("show");

      setTimeout(() => {
        toast.classList.remove("show");
      }, 3200);
    }

    document.getElementById("breakfastForm").addEventListener("submit", function(e) {
      e.preventDefault();

      const selectedFoods = Array.from(document.querySelectorAll('input[name="food"]:checked'))
        .map(input => input.value);

      const notes = document.getElementById("notes").value.trim();

      if (selectedFoods.length === 0) {
        showToast("Seleziona almeno una voce per la colazione.");
        return;
      }

      const subject = `Ordine colazione - Camera ${room}`;

      const body =
`Nuovo ordine colazione

B&B: ${CONFIG.nomeBB}
Camera: ${room}

Cibi scelti:
- ${selectedFoods.join("\n- ")}

Note:
${notes || "Nessuna nota"}

Ordine inviato da QR code camera ${room}.`;

      const mailto =
        `mailto:${CONFIG.emailDestinatario}` +
        `?subject=${encodeURIComponent(subject)}` +
        `&body=${encodeURIComponent(body)}`;

      showToast("Ordine preparato. Si aprirà l'email di invio.");

      setTimeout(() => {
        window.location.href = mailto;
      }, 650);
    });
  </script>
</body>
</html>